# 민감 정보 절대 커밋 금지
.env
*.env
secrets/
api_keys.md

# 머신별 로컬 설정 (다중 PC 환경 - 절대 커밋 금지)
config.local.json

# 개인 PC 사용량 데이터 (머신마다 다름 — 커밋 금지)
data/usage.json

# 대용량 데이터 파일
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.json
models/*.pkl
models/*.h5
models/*.pt

# 임시 파일
*.tmp
*.log
__pycache__/
.DS_Store
Thumbs.db

# mem0 벡터 DB (로컬 전용, 크기 큼)
.mem0/

# 패치 작업 디렉터리
_patches/

# 월별 아카이브 로그 (로컬 전용)
logs/

# 백업 파일 (git 내부 누적 방지)
_backup/
*.bak
agent_collab.json
.env

# 인프라 설치 파일 (대용량 바이너리)
infrastructure/*.msi
infrastructure/*.exe

# 병합 충돌 잔재 / 임시 백업 파일
*.backup.html
*.local
*.remote
.venv/

# 옵시디언 Vault (wiki/) — 설정은 추적, 휘발 상태는 제외
wiki/.obsidian/workspace.json
wiki/.obsidian/workspace-mobile.json
wiki/.obsidian/cache
wiki/.trash/
wiki/_attachments/

# 중첩 vault 영구 차단 — Obsidian을 wiki/ 대신 wiki/wiki/ 폴더 기준으로 열었을 때 생기는 중복
# git pull 후 자동 복원되지 않도록 추적 완전 제거
wiki/wiki/
.compact_pending

# wiki/notes 루트 직접 저장 방지 — 반드시 하위폴더(feedback/project/reference/method)에만 저장
# git add wiki/notes/*.md 또는 git add wiki/notes 시 루트 파일 자동 제외
wiki/notes/*.md
